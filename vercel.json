{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/api/openrouter", "dest": "/api/openrouter.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
